---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact">
	<Header />
	
	<main>
		<!-- Page Header -->
		<section class="page-header">
			<div class="page-header-bg"></div>
			<div class="container">
				<span class="page-badge scroll-reveal">Get In Touch</span>
				<h1 class="scroll-reveal">Contact Us</h1>
				<p class="scroll-reveal">We're here to help! Reach out for any inquiries</p>
			</div>
		</section>
		
		<!-- Contact Section -->
		<section class="contact-section section">
			<div class="container">
				<div class="contact-grid">
					<!-- Contact Info -->
					<div class="contact-info scroll-reveal">
						<div class="section-header" style="text-align: left;">
							<h2>Get In Touch</h2>
							<p>Have questions? We'd love to hear from you. Send us a message or call us during business hours.</p>
						</div>
						
						<div class="contact-items">
							<div class="contact-item">
								<div class="contact-icon">
									<i class="fas fa-building"></i>
								</div>
								<div>
									<h4>Main Office</h4>
									<p><strong>JOPCA CORPORATION</strong></p>
									<span>#54, National Highway, Prk. 1, Gusa, Cagayan de Oro</span>
									<span>0917 728 6501</span>
								</div>
							</div>
							
							<div class="contact-item">
								<div class="contact-icon">
									<i class="fas fa-tools"></i>
								</div>
								<div>
									<h4>Truck Parts Plant</h4>
									<p><strong>JOPCA Truck Parts Trading</strong></p>
									<span>National Highway, Zone 12, Brgy. Poblacion, Tagoloan</span>
									<span>0917 506 4427</span>
								</div>
							</div>
							
							<div class="contact-item">
								<div class="contact-icon">
									<i class="fas fa-envelope"></i>
								</div>
								<div>
									<h4>Email Us</h4>
									<p>jopcaconstructionsupply@gmail.com</p>
									<span class="contact-note">For construction inquiries</span>
								</div>
							</div>
							
							<div class="contact-item">
								<div class="contact-icon">
									<i class="fas fa-clock"></i>
								</div>
								<div>
									<h4>Business Hours</h4>
									<p>Monday - Saturday: 8:00 AM - 5:00 PM</p>
									<span class="contact-note">Sunday: CLOSED</span>
								</div>
							</div>
						</div>
						
						<div class="social-section">
							<h4>Follow Us</h4>
							<div class="social-links">
								<a href="https://www.facebook.com/jopcaconstructionsupplyinc" target="_blank" class="social-link"><i class="fab fa-facebook-f"></i></a>
								<a href="https://www.facebook.com/profile.php?id=100064140399806" target="_blank" class="social-link"><i class="fas fa-truck"></i></a>
								<a href="#" class="social-link" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
							</div>
						</div>
					</div>
					
					<!-- Contact Form -->
					<div class="contact-form-wrapper scroll-reveal">
						<div class="contact-form-card">
							<h3>Send Us a Message</h3>
							<p>Fill out the form below and we'll get back to you within 24 hours.</p>
							
							<form id="contactForm" class="contact-form" action="mailto:jopcaconstructionsupply@gmail.com" method="post" enctype="text/plain">
								<div class="form-row">
									<div class="form-group">
										<label for="name">Full Name *</label>
										<input type="text" id="name" name="name" required placeholder="John Doe" />
									</div>
									
									<div class="form-group">
										<label for="company">Company</label>
										<input type="text" id="company" name="company" placeholder="Your Company" />
									</div>
								</div>
								
								<div class="form-row">
									<div class="form-group">
										<label for="email">Email Address *</label>
										<input type="email" id="email" name="email" required placeholder="john@example.com" />
									</div>
									
									<div class="form-group">
										<label for="phone">Phone Number</label>
										<input type="tel" id="phone" name="phone" placeholder="+63 XXX XXX XXXX" />
									</div>
								</div>
								
								<div class="form-group">
									<label for="inquiryType">Inquiry Type *</label>
									<select id="inquiryType" name="inquiryType" required>
										<option value="">Select inquiry type</option>
										<option value="truck_parts">Truck Parts</option>
										<option value="construction">Construction Services</option>
										<option value="fleet_maintenance">Fleet Maintenance</option>
										<option value="quote">Request Quote</option>
										<option value="other">Other</option>
									</select>
								</div>
								
								<div class="form-group">
									<label for="message">Message *</label>
									<textarea id="message" name="message" rows="5" required placeholder="Tell us about your requirements..."></textarea>
								</div>
								
								<button type="submit" class="btn btn-glow">
									<i class="fas fa-paper-plane"></i>
									Send Message
								</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Map Section -->
		<section class="map-section">
			<div class="container">
				<div class="map-wrapper">
					<div class="map-placeholder">
						<i class="fas fa-map-marked-alt"></i>
						<p>Google Map will be displayed here</p>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>

<style>
	/* Page Header */
	.page-header {
		position: relative;
		padding: 180px 0 100px;
		text-align: center;
		overflow: hidden;
	}
	
	.page-header-bg {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
	}
	
	.page-header-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(26, 26, 46, 0.92) 0%, rgba(22, 33, 62, 0.88) 100%);
	}
	
	.page-header .container { position: relative; z-index: 2; }
	
	.page-badge {
		display: inline-block;
		background: rgba(233, 69, 96, 0.2);
		color: var(--accent);
		padding: 10px 24px;
		border-radius: 30px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 25px;
		letter-spacing: 1px;
	}
	
	.page-header h1 {
		font-size: 3.75rem;
		color: var(--white);
		margin-bottom: 20px;
	}
	
	.page-header p {
		color: rgba(255, 255, 255, 0.85);
		font-size: 1.15rem;
	}
	
	/* Contact Section */
	.contact-section { background: var(--white); padding: 80px 0; }
	
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.5fr;
		gap: 60px;
		align-items: start;
	}
	
	.contact-info > .section-header p { margin-left: 0; max-width: 100%; }
	
	.contact-items { display: flex; flex-direction: column; gap: 30px; margin-bottom: 45px; }
	
	.contact-item { display: flex; gap: 20px; align-items: flex-start; }
	
	.contact-icon {
		width: 60px;
		height: 60px;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	
	.contact-icon i { font-size: 1.25rem; color: var(--white); }
	
	.contact-item h4 { margin-bottom: 6px; color: var(--primary); }
	.contact-item p { color: var(--gray); margin-bottom: 4px; }
	.contact-note { color: var(--gray-light); font-size: 0.85rem; }
	
	.social-section h4 { margin-bottom: 18px; color: var(--primary); }
	
	.social-links { display: flex; gap: 14px; }
	
	.social-link {
		width: 45px;
		height: 45px;
		background: var(--light);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}
	
	.social-link:hover {
		background: var(--accent);
		transform: translateY(-4px);
	}
	
	.social-link i { color: var(--primary); font-size: 1rem; }
	.social-link:hover i { color: var(--white); }
	
	/* Form */
	.contact-form-card {
		background: var(--white);
		padding: 45px;
		border-radius: 20px;
		box-shadow: 0 10px 50px rgba(0, 0, 0, 0.1);
		border: 1px solid var(--border);
	}
	
	.contact-form-card h3 { font-size: 1.45rem; margin-bottom: 12px; color: var(--primary); }
	.contact-form-card > p { color: var(--gray); margin-bottom: 32px; }
	
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
	
	.form-group { margin-bottom: 22px; }
	
	.form-group label {
		display: block;
		margin-bottom: 10px;
		font-weight: 500;
		color: var(--primary);
		font-size: 0.95rem;
	}
	
	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 15px 20px;
		border: 1px solid var(--border);
		border-radius: 10px;
		font-size: 1rem;
		transition: all 0.3s ease;
		background: var(--white);
	}
	
	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 4px rgba(233, 69, 96, 0.1);
	}
	
	.form-group textarea { resize: vertical; min-height: 130px; }
	
	.contact-form .btn {
		width: 100%;
		padding: 18px;
		font-size: 1.05rem;
	}
	
	.btn-glow {
		background: var(--accent);
		color: var(--white);
	}
	
	.btn-glow:hover {
		background: var(--accent-hover);
		box-shadow: 0 0 30px rgba(233, 69, 96, 0.5);
	}
	
	/* Map */
	.map-section { padding-bottom: 80px; }
	
	.map-wrapper {
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 8px 35px rgba(0, 0, 0, 0.08);
	}
	
	.map-placeholder {
		background: var(--light);
		height: 380px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 18px;
	}
	
	.map-placeholder i { font-size: 3.5rem; color: var(--gray-light); }
	.map-placeholder p { color: var(--gray); font-size: 1.1rem; font-weight: 500; }
	
	/* Scroll Animation */
	.scroll-reveal {
		opacity: 0;
		transform: translateY(40px);
		transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
	}
	
	.scroll-reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}
	
	@media (max-width: 992px) {
		.contact-grid { grid-template-columns: 1fr; gap: 45px; }
		.form-row { grid-template-columns: 1fr; }
		.page-header h1 { font-size: 2.75rem; }
	}
	
	@media (max-width: 576px) {
		.contact-form-card { padding: 32px 22px; }
	}
</style>

<script>
	const scrollObserver = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) entry.target.classList.add('visible');
		});
	}, { threshold: 0.1 });
	
	document.querySelectorAll('.scroll-reveal').forEach(el => scrollObserver.observe(el));
	
	// Form submit
	const form = document.getElementById('contactForm');
	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		alert('Thank you for your inquiry! We will get back to you within 24 hours.');
		form.reset();
	});
</script>