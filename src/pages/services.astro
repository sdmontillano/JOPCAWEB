---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
	{
		id: 1,
		title: "Truck Parts Supply",
		description: "Quality truck parts for all major brands. We supply genuine and aftermarket parts for various truck models with competitive pricing and fast delivery.",
		icon: "fa-truck-loading",
		features: ["Genuine Parts", "Aftermarket Options", "Wide Inventory", "Competitive Prices", "Fast Delivery", "Technical Support"]
	},
	{
		id: 2,
		title: "Ready Mix Concrete",
		description: "Quality ready mix concrete for all your construction needs. We supply reliable and consistent concrete for commercial and residential projects.",
		icon: "fa-industry",
		features: ["Quality Concrete", "Reliable Supply", "On-time Delivery", "Competitive Prices", "Custom Mix", "Technical Support"]
	},
	{
		id: 3,
		title: "Rental Service",
		description: "We offer truck rental services for sand delivery and concrete mixing needs. Contact us to inquire about available units and rates.",
		icon: "fa-truck-moving",
		features: ["10 Wheeler Dump Truck", "10 Wheeler Mixer Truck", "1cu.m Bucket Backhoe", "37m Sky Pumpcrete", "3cu.m Wheel Loader"]
	}
];

const products = [
	{ category: "Engine Parts", items: ["Pistons & Rings", "Crankshaft", "Cylinder Head", "Gasket Sets", "Oil Pump", "Water Pump"] },
	{ category: "Transmission", items: ["Gearboxes", "Clutch Plates", "Transmission Fluid", "Drive Shafts", "U-Joints", "Differentials"] },
	{ category: "Brake Systems", items: ["Brake Pads", "Brake Drums", "ABS Controllers", "Brake Lines", "Master Cylinder", "Wheel Cylinder"] },
	{ category: "Suspension", items: ["Shock Absorbers", "Leaf Springs", "Air Bags", "Bushings", "Tie Rods", "Ball Joints"] },
	{ category: "Electrical", items: ["Alternators", "Starters", "Batteries", "Wiring Harness", "Sensors", "Lights"] },
	{ category: "Body Parts", items: ["Mirrors", "Bumpers", "Grilles", "Fenders", "Mudguards", "Steps"] }
];
---

<Layout title="Services">
	<Header />
	
	<main>
		<!-- Page Header -->
		<section class="page-header">
			<div class="page-header-bg"></div>
			<div class="page-header-overlay"></div>
			<div class="container">
				<span class="page-badge scroll-reveal">What We Offer</span>
				<h1 class="scroll-reveal">Services & Products</h1>
				<p class="scroll-reveal">Professional truck parts trading and construction supply</p>
			</div>
		</section>
		
		<!-- Services Section -->
		<section class="services-section section">
			<div class="container">
				<div class="section-header scroll-reveal">
					<h2>What We Supply</h2>
					<p>Quality truck parts and materials for your needs</p>
				</div>
				
				<div class="services-grid">
					{services.map((service, index) => (
						<div class="service-card scroll-reveal">
							<div class="service-header">
								<div class="service-icon">
									<i class={`fas ${service.icon}`}></i>
								</div>
								<span class="service-number">0{service.id}</span>
							</div>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
							<ul class="service-features">
								{service.features.map((feature) => (
									<li><i class="fas fa-check"></i>{feature}</li>
								))} 
							</ul>
						</div>
					))}
				</div>
			</div>
		</section>
		
		<!-- Rental Fleet Section -->
		<section class="rental-fleet section">
			<div class="container">
				<div class="section-header scroll-reveal">
					<h2>Our Rental Fleet</h2>
					<p>Available units for rent</p>
				</div>
				
				<div class="rental-grid">
					<div class="rental-card scroll-reveal">
						<div class="rental-image">
							<img src="/images/parts20.jpg" alt="10 Wheeler Dump Truck" loading="lazy" />
						</div>
						<div class="rental-info">
							<h3>10 Wheeler Dump Truck</h3>
						</div>
					</div>
					
					<div class="rental-card scroll-reveal">
						<div class="rental-image">
							<img src="/images/parts21.jpg" alt="10 Wheeler Mixer Truck" loading="lazy" />
						</div>
						<div class="rental-info">
							<h3>10 Wheeler Mixer Truck</h3>
						</div>
					</div>
					
					<div class="rental-card scroll-reveal">
						<div class="rental-image">
							<img src="/images/parts22.jpg" alt="1cu.m Bucket Backhoe" loading="lazy" />
						</div>
						<div class="rental-info">
							<h3>1cu.m Bucket Backhoe</h3>
						</div>
					</div>
					
					<div class="rental-card scroll-reveal">
						<div class="rental-info">
							<h3>37m Sky Pumpcrete</h3>
						</div>
					</div>
					
					<div class="rental-card scroll-reveal">
						<div class="rental-info">
							<h3>3cu.m Wheel Loader</h3>
						</div>
					</div>
				</div>
			</div>
		</section>
		
		<!-- Products Section -->
		<section class="products-section section">
			<div class="container">
				<div class="section-header scroll-reveal">
					<h2>Truck Parts Catalog</h2>
					<p>Wide range of quality parts for various truck brands and models</p>
				</div>
				
				<div class="products-grid">
					{products.map((product, index) => (
						<div class="product-card scroll-reveal">
							<h3>{product.category}</h3>
							<ul>
								{product.items.map((item) => (<li>{item}</li>))} 
							</ul>
							<a href="/contact" class="product-link">Inquire <i class="fas fa-arrow-right"></i></a>
						</div>
					))}
				</div>
			</div>
		</section>
		
		<!-- CTA -->
		<section class="cta-section">
			<div class="cta-bg">
				<img src="/images/background.jpg" alt="CTA" />
				<div class="cta-overlay"></div>
			</div>
			<div class="container">
				<div class="cta-content scroll-reveal">
					<h2>Need Help Choosing Parts?</h2>
					<p>Our experts are here to help you find the right parts for your needs.</p>
					<a href="/contact" class="btn btn-glow">Get Expert Help</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>

<style>
	/* Page Header */
	.page-header {
		position: relative;
		padding: 180px 0 100px;
		text-align: center;
		overflow: hidden;
	}
	
	.page-header-bg {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: url('/images/parts17.jpg') center/cover no-repeat;
	}
	
	.page-header-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(26, 26, 46, 0.85) 0%, rgba(22, 33, 62, 0.8) 100%);
	}
	
	.page-header-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(26, 26, 46, 0.92) 0%, rgba(22, 33, 62, 0.88) 100%);
	}
	
	.page-header .container { position: relative; z-index: 2; }
	
	.page-badge {
		display: inline-block;
		background: rgba(233, 69, 96, 0.2);
		color: var(--accent);
		padding: 10px 24px;
		border-radius: 30px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 25px;
		letter-spacing: 1px;
	}
	
	.page-header h1 {
		font-size: 3.75rem;
		color: var(--white);
		margin-bottom: 20px;
	}
	
	.page-header p {
		color: rgba(255, 255, 255, 0.85);
		font-size: 1.15rem;
	}
	
	/* Services Grid */
	.services-section { background: var(--white); }
	
	.services-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 35px;
	}
	
	.service-card {
		background: var(--white);
		padding: 40px;
		border-radius: 16px;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
		border: 1px solid var(--border);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}
	
	.service-card:hover {
		transform: translateY(-12px);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
		border-color: var(--accent);
	}
	
	.service-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 25px;
	}
	
	.service-icon {
		width: 75px;
		height: 75px;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	
	.service-icon i {
		font-size: 1.8rem;
		color: var(--white);
	}
	
	.service-number {
		font-size: 3.5rem;
		font-weight: 800;
		color: var(--border);
	}
	
	.service-card h3 {
		font-size: 1.4rem;
		margin-bottom: 15px;
		color: var(--primary);
	}
	
	.service-card > p {
		color: var(--gray);
		margin-bottom: 25px;
		line-height: 1.8;
	}
	
	.service-features {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}
	
	.service-features li {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--gray);
		font-size: 0.9rem;
	}
	
	.service-features li i {
		color: var(--accent);
		font-size: 0.75rem;
	}
	
	/* Products */
	.products-section { background: var(--light); }
	
	.products-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
	}
	
	.product-card {
		background: var(--white);
		padding: 30px;
		border-radius: 16px;
		box-shadow: 0 4px 25px rgba(0, 0, 0, 0.06);
		transition: all 0.4s ease;
	}
	
	.product-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
	}
	
	.product-card h3 {
		font-size: 1.15rem;
		margin-bottom: 20px;
		padding-bottom: 15px;
		border-bottom: 2px solid var(--accent);
		color: var(--primary);
	}
	
	.product-card ul { list-style: none; margin-bottom: 20px; }
	
	.product-card li {
		padding: 10px 0;
		color: var(--gray);
		border-bottom: 1px solid var(--border);
		font-size: 0.9rem;
	}
	
	.product-card li:last-child { border-bottom: none; }
	
	.product-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--accent);
		font-weight: 600;
	}
	
	.product-link:hover { gap: 14px; }
	
	/* CTA */
	.cta-section { position: relative; overflow: hidden; }
	
	.cta-bg {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
	}
	
	.cta-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(233, 69, 96, 0.95) 0%, rgba(233, 69, 96, 0.85) 100%);
	}
	
	.cta-content {
		position: relative;
		z-index: 2;
		text-align: center;
		max-width: 600px;
		margin: 0 auto;
		padding: 100px 0;
	}
	
	.cta-content h2 {
		color: var(--white);
		font-size: 2.8rem;
		margin-bottom: 20px;
	}
	
	.cta-content p {
		color: rgba(255, 255, 255, 0.9);
		margin-bottom: 35px;
		font-size: 1.15rem;
	}
	
	.btn-glow {
		background: var(--white);
		color: var(--accent);
	}
	
	.btn-glow:hover {
		background: var(--primary);
		color: var(--white);
		box-shadow: 0 0 30px rgba(255, 255, 255, 0.3);
	}
	
	/* Rental Fleet */
	.rental-fleet { background: var(--light); }
	
	.rental-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 30px;
	}
	
	.rental-card {
		background: var(--white);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 4px 25px rgba(0, 0, 0, 0.06);
		transition: all 0.4s ease;
	}
	
	.rental-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
	}
	
	.rental-image {
		aspect-ratio: 16/10;
		overflow: hidden;
		background: var(--gray-light);
	}
	
	.rental-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}
	
	.rental-card:hover .rental-image img {
		transform: scale(1.1);
	}
	
	.rental-info {
		padding: 25px;
		text-align: center;
	}
	
	.rental-info h3 {
		font-size: 1.15rem;
		color: var(--primary);
	}
	
	@media (max-width: 992px) {
		.rental-grid { grid-template-columns: repeat(2, 1fr); }
	}
	
	@media (max-width: 576px) {
		.rental-grid { grid-template-columns: 1fr; }
	}
	
	/* Scroll Animation */
	.scroll-reveal {
		opacity: 0;
		transform: translateY(40px);
		transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
	}
	
	.scroll-reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}
	
	@media (max-width: 992px) {
		.services-grid, .products-grid { grid-template-columns: 1fr; }
		.page-header h1 { font-size: 2.75rem; }
	}
</style>

<script>
	const scrollObserver = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) entry.target.classList.add('visible');
		});
	}, { threshold: 0.1 });
	
	document.querySelectorAll('.scroll-reveal').forEach(el => scrollObserver.observe(el));
</script>