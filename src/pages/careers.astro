---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jobOpenings = [
	{
		title: "Truck Parts Sales Executive",
		type: "Full-time",
		location: "Cagayan de Oro",
		description: "Sell truck parts to clients, maintain customer relationships, meet sales targets.",
		requirements: ["Experience in sales", "Good communication skills", "Valid driver's license"]
	},
	{
		title: "Mechanic/Technician",
		type: "Full-time",
		location: "Tagoloan Plant",
		description: "Repair and maintain truck parts, perform diagnostics, ensure quality service.",
		requirements: ["Technical experience", "Knowledge of truck parts", "Problem-solving skills"]
	},
	{
		title: "Construction Worker",
		type: "Full-time",
		location: "Various Sites",
		description: "Assist in construction projects, follow safety protocols, work with team.",
		requirements: ["Physical fitness", "Team player", "Construction experience preferred"]
	},
	{
		title: "Administrative Staff",
		type: "Full-time",
		location: "Gusa Office",
		description: "Handle paperwork, customer service, inventory management.",
		requirements: ["Computer literate", "Good organizational skills", "Communication skills"]
	}
];

const benefits = [
	{ icon: "fa-money-bill-wave", title: "Competitive Salary", description: "Attractive pay packages" },
	{ icon: "fa-calendar-check", title: "Regular Hours", description: "Monday to Saturday, 8AM-5PM" },
	{ icon: "fa-user-tie", title: "Career Growth", description: "Professional development" },
	{ icon: "fa-hard-hat", title: "Safe Environment", description: "OSHA-compliant workplace" }
];
---

<Layout title="Careers">
	<Header />
	
	<main>
		<!-- Hero Section -->
		<section class="page-header">
			<div class="page-header-bg"></div>
			<div class="container">
				<span class="page-badge scroll-reveal">Join Our Team</span>
				<h1 class="scroll-reveal">Careers at JOPCA</h1>
				<p class="scroll-reveal">Build your career with a trusted industry leader</p>
			</div>
		</section>
		
		<!-- Benefits Section -->
		<section class="benefits-section section">
			<div class="container">
				<div class="section-header scroll-reveal">
					<h2>Why Work With Us?</h2>
					<p>Join a company that values its employees</p>
				</div>
				
				<div class="benefits-grid">
					{benefits.map((benefit, index) => (
						<div class="benefit-card scroll-reveal" style={`animation-delay: ${index * 0.1}s`}>
							<div class="benefit-icon">
								<i class={`fas ${benefit.icon}`}></i>
							</div>
							<h3>{benefit.title}</h3>
							<p>{benefit.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>
		
		<!-- Job Openings Section -->
		<section class="jobs-section section">
			<div class="container">
				<div class="section-header scroll-reveal">
					<h2>Current Openings</h2>
					<p>Find the perfect role for your skills</p>
				</div>
				
				<div class="jobs-grid">
					{jobOpenings.map((job, index) => (
						<div class="job-card scroll-reveal" style={`animation-delay: ${index * 0.1}s`}>
							<div class="job-header">
								<h3>{job.title}</h3>
								<span class="job-type">{job.type}</span>
							</div>
							<p class="job-location"><i class="fas fa-map-marker-alt"></i> {job.location}</p>
							<p class="job-description">{job.description}</p>
							<div class="job-requirements">
								<h4>Requirements:</h4>
								<ul>
									{job.requirements.map((req) => (
										<li><i class="fas fa-check"></i> {req}</li>
									))}
								</ul>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
		
		<!-- How to Apply Section -->
		<section class="apply-section">
			<div class="apply-bg"></div>
			<div class="container">
				<div class="apply-content scroll-reveal">
					<h2>How to Apply</h2>
					<p>Send your resume or inquiry to our HR department</p>
					
					<div class="apply-options">
						<div class="apply-option">
							<div class="apply-icon">
								<i class="fas fa-envelope"></i>
							</div>
							<h4>Via Email</h4>
							<p>jopca.hrdept@gmail.com</p>
						</div>
						
						<div class="apply-option">
							<div class="apply-icon">
								<i class="fas fa-phone-alt"></i>
							</div>
							<h4>Call Us</h4>
							<p>0907 876 2280</p>
						</div>
						
						<div class="apply-option">
							<div class="apply-icon">
								<i class="fab fa-facebook-f"></i>
							</div>
							<h4>Facebook</h4>
							<a href="https://www.facebook.com/profile.php?id=61578682695886" target="_blank">Message HR</a>
						</div>
						
						<div class="apply-option">
							<div class="apply-icon">
								<i class="fas fa-map-marker-alt"></i>
							</div>
							<h4>Visit Us</h4>
							<p>54 National Highway, Purok 1, Gusa, Cagayan de Oro</p>
						</div>
					</div>
					
					<a href="/contact" class="btn btn-glow">Send Inquiry</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>

<style>
	/* Page Header */
	.page-header {
		position: relative;
		padding: 160px 0 100px;
		text-align: center;
		overflow: hidden;
		background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
	}
	
	.page-header .container { position: relative; z-index: 2; }
	
	.page-badge {
		display: inline-block;
		background: rgba(233, 69, 96, 0.2);
		color: var(--accent);
		padding: 10px 24px;
		border-radius: 30px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 25px;
		letter-spacing: 1px;
	}
	
	.page-header h1 {
		font-size: 3.5rem;
		color: var(--white);
		margin-bottom: 15px;
	}
	
	.page-header p {
		color: rgba(255, 255, 255, 0.85);
		font-size: 1.15rem;
	}
	
	/* Benefits */
	.benefits-section { background: var(--white); }
	
	.benefits-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 25px;
	}
	
	.benefit-card {
		background: var(--white);
		padding: 35px 25px;
		border-radius: 16px;
		text-align: center;
		box-shadow: 0 4px 25px rgba(0, 0, 0, 0.06);
		transition: all 0.4s ease;
		border: 1px solid var(--border);
	}
	
	.benefit-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
	}
	
	.benefit-icon {
		width: 65px;
		height: 65px;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 20px;
	}
	
	.benefit-icon i {
		font-size: 1.5rem;
		color: var(--white);
	}
	
	.benefit-card h3 {
		font-size: 1.15rem;
		margin-bottom: 10px;
		color: var(--primary);
	}
	
	.benefit-card p {
		color: var(--gray);
		font-size: 0.9rem;
	}
	
	/* Jobs */
	.jobs-section { background: var(--light); }
	
	.jobs-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 25px;
	}
	
	.job-card {
		background: var(--white);
		padding: 30px;
		border-radius: 16px;
		box-shadow: 0 4px 25px rgba(0, 0, 0, 0.06);
		transition: all 0.4s ease;
	}
	
	.job-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
	}
	
	.job-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 15px;
	}
	
	.job-header h3 {
		font-size: 1.25rem;
		color: var(--primary);
	}
	
	.job-type {
		background: rgba(233, 69, 96, 0.1);
		color: var(--accent);
		padding: 5px 12px;
		border-radius: 20px;
		font-size: 0.8rem;
		font-weight: 600;
	}
	
	.job-location {
		color: var(--gray);
		font-size: 0.9rem;
		margin-bottom: 15px;
	}
	
	.job-location i { margin-right: 6px; }
	
	.job-description {
		color: var(--gray);
		margin-bottom: 18px;
		line-height: 1.6;
	}
	
	.job-requirements h4 {
		font-size: 0.9rem;
		color: var(--primary);
		margin-bottom: 10px;
	}
	
	.job-requirements ul { list-style: none; }
	
	.job-requirements li {
		padding: 6px 0;
		color: var(--gray);
		font-size: 0.9rem;
	}
	
	.job-requirements li i {
		color: var(--accent);
		margin-right: 8px;
		font-size: 0.8rem;
	}
	
	/* Apply Section */
	.apply-section {
		position: relative;
		padding: 80px 0;
		overflow: hidden;
	}
	
	.apply-bg {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
	}
	
	.apply-content {
		position: relative;
		z-index: 2;
		text-align: center;
	}
	
	.apply-content h2 {
		color: var(--white);
		font-size: 2.5rem;
		margin-bottom: 15px;
	}
	
	.apply-content > p {
		color: rgba(255, 255, 255, 0.9);
		margin-bottom: 40px;
	}
	
	.apply-options {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 25px;
		margin-bottom: 40px;
	}
	
	.apply-option {
		background: rgba(255, 255, 255, 0.15);
		padding: 30px 20px;
		border-radius: 16px;
		transition: all 0.3s ease;
	}
	
	.apply-option:hover {
		background: rgba(255, 255, 255, 0.25);
	}
	
	.apply-icon {
		width: 55px;
		height: 55px;
		background: rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 18px;
	}
	
	.apply-icon i {
		font-size: 1.3rem;
		color: var(--white);
	}
	
	.apply-option h4 {
		color: var(--white);
		font-size: 1rem;
		margin-bottom: 10px;
	}
	
	.apply-option p,
	.apply-option a {
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.95rem;
	}
	
	.apply-option a:hover {
		color: var(--white);
		text-decoration: underline;
	}
	
	/* Button */
	.btn-glow {
		background: var(--white);
		color: var(--accent);
		padding: 16px 36px;
		font-size: 1.05rem;
	}
	
	.btn-glow:hover {
		background: var(--primary);
		color: var(--white);
	}
	
	/* Scroll Animation */
	.scroll-reveal {
		opacity: 0;
		transform: translateY(40px);
		transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
	}
	
	.scroll-reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}
	
	/* Responsive */
	@media (max-width: 992px) {
		.benefits-grid,
		.apply-options { grid-template-columns: repeat(2, 1fr); }
		.jobs-grid { grid-template-columns: 1fr; }
	}
	
	@media (max-width: 576px) {
		.benefits-grid,
		.apply-options { grid-template-columns: 1fr; }
		.page-header h1 { font-size: 2.5rem; }
	}
</style>

<script>
	const scrollObserver = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) entry.target.classList.add('visible');
		});
	}, { threshold: 0.1 });
	
	document.querySelectorAll('.scroll-reveal').forEach(el => scrollObserver.observe(el));
</script>