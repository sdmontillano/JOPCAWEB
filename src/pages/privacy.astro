---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy">
	<Header />
	
	<main>
		<section class="page-header">
			<div class="page-header-bg"></div>
			<div class="container">
				<h1>Privacy Policy</h1>
				<p>Your privacy is important to us</p>
			</div>
		</section>
		
		<section class="content-section">
			<div class="container">
				<div class="policy-content">
					<p class="last-updated">Last Updated: April 2026</p>
					
					<h2>Introduction</h2>
					<p>JOPCA CORPORATION ("we," "our," or "us") operates the JOPCA CORPORATION website. This page informs you of our policies regarding the collection, use, and disclosure of personal data when you use our service.</p>
					
					<h2>Information We Collect</h2>
					<p>When you visit our website, we may collect:</p>
					<ul>
						<li>Personal information you provide (name, email, phone number) through contact forms</li>
						<li>Usage data such as browser type, operating system, and access times</li>
						<li>Cookies for website functionality and analytics</li>
					</ul>
					
					<h2>How We Use Your Information</h2>
					<p>We use the collected information to:</p>
					<ul>
						<li>Provide and maintain our services</li>
						<li>Notify you about changes to our services</li>
						<li>Provide customer support</li>
						<li>Respond to your inquiries</li>
						<li>Improve our website and services</li>
					</ul>
					
					<h2>Data Security</h2>
					<p>The security of your personal information is important to us. We implement appropriate security measures to protect your data. However, no method of transmission over the Internet is 100% secure.</p>
					
					<h2>Cookies</h2>
					<p>Our website uses cookies to enhance user experience. By using our website, you consent to the use of cookies.</p>
					
					<h2>Third-Party Services</h2>
					<p>We may use third-party service providers to assist in operating our website. These parties have access to personal information only to perform tasks on our behalf.</p>
					
					<h2>Changes to This Policy</h2>
					<p>We may update this policy from time to time. We will notify you of any changes by posting the new policy on this page.</p>
					
					<h2>Contact Us</h2>
					<p>If you have any questions about this Privacy Policy, please contact us:</p>
					<ul class="contact-info">
						<li><strong>JOPCA CORPORATION</strong></li>
						<li>#54, National Highway, Prk. 1, Gusa, Cagayan de Oro</li>
						<li>Phone: 0917 728 6501</li>
						<li>Email: jopcaconstructionsupply@gmail.com</li>
					</ul>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>

<style>
	.page-header {
		position: relative;
		padding: 140px 0 80px;
		text-align: center;
		background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
	}
	
	.page-header-bg {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
	}
	
	.page-header .container {
		position: relative;
		z-index: 2;
	}
	
	.page-header h1 {
		font-size: 3rem;
		color: var(--white);
		margin-bottom: 15px;
	}
	
	.page-header p {
		color: rgba(255, 255, 255, 0.85);
		font-size: 1.1rem;
	}
	
	.content-section {
		padding: 80px 0;
		background: var(--white);
	}
	
	.policy-content {
		max-width: 800px;
		margin: 0 auto;
	}
	
	.last-updated {
		color: var(--gray);
		font-size: 0.9rem;
		margin-bottom: 40px;
	}
	
	.policy-content h2 {
		font-size: 1.4rem;
		margin: 40px 0 20px;
		color: var(--primary);
	}
	
	.policy-content h2:first-of-type {
		margin-top: 0;
	}
	
	.policy-content p {
		color: var(--gray);
		line-height: 1.8;
		margin-bottom: 15px;
	}
	
	.policy-content ul {
		list-style: none;
		margin: 15px 0;
	}
	
	.policy-content ul li {
		padding: 10px 0;
		padding-left: 25px;
		position: relative;
		color: var(--gray);
		line-height: 1.7;
	}
	
	.policy-content ul li::before {
		content: '•';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-weight: bold;
	}
	
	.contact-info {
		background: var(--light);
		padding: 30px !important;
		border-radius: 12px;
		margin-top: 20px !important;
	}
	
	.contact-info li {
		padding: 8px 0 !important;
		padding-left: 0 !important;
	}
	
	.contact-info li::before {
		display: none;
	}
	
	.contact-info strong {
		color: var(--primary);
	}
	
	@media (max-width: 768px) {
		.page-header h1 {
			font-size: 2.25rem;
		}
	}
</style>